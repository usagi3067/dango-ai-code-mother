# screenshot-app 基础镜像：JRE + Chromium + 中文字体
# 构建后传到目标机器，只需传一次
FROM eclipse-temurin:21-jre-alpine
WORKDIR /app

# 换 Alpine 国内镜像源
RUN sed -i 's/dl-cdn.alpinelinux.org/mirrors.aliyun.com/g' /etc/apk/repositories

# 安装 Chromium + ChromeDriver + 中文字体
RUN apk add --no-cache chromium chromium-chromedriver nss freetype harfbuzz \
    ca-certificates ttf-freefont font-noto-cjk fontconfig \
    && fc-cache -f

ENV CHROME_BIN=/usr/bin/chromium-browser
ENV CHROMEDRIVER_PATH=/usr/bin/chromedriver
