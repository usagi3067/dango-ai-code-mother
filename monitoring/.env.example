# ========================================
# Grafana 监控栈环境变量
# 复制为 .env 并填入实际值
# ========================================

# Grafana 管理员密码
GF_SECURITY_ADMIN_PASSWORD=your_secure_password

# ---- 邮件告警（QQ 邮箱 SMTP，免费） ----
# 1. 登录 QQ 邮箱 → 设置 → 账户 → 开启 POP3/SMTP 服务
# 2. 发短信验证后获得 16 位授权码，填入 SMTP_AUTH_PASSWORD
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_FROM=your_qq@qq.com
SMTP_AUTH_PASSWORD=your_16_char_auth_code
ALERT_EMAIL_TO=your_email@qq.com

# ---- MySQL 数据源（Grafana 业务指标 Dashboard） ----
# 需要先在 RDS 上创建只读账号，参考 backend/sql/create_readonly_user.sql
MYSQL_GRAFANA_HOST=rm-cn-sn34m8htv0001kxo.rwlb.rds.aliyuncs.com
MYSQL_GRAFANA_PORT=3306
MYSQL_GRAFANA_DATABASE=dango_ai_code_mother_prod
MYSQL_GRAFANA_USER=grafana_reader
MYSQL_GRAFANA_PASSWORD=your_grafana_readonly_password

# ---- 阿里云 Redis（redis-exporter + Grafana 直连） ----
REDIS_HOST=r-cn-xxx.redis.rds.aliyuncs.com
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
